# Скопируй в .env и заполни

# --- Telegram (@BotFather) ---
BOT_TOKEN=123456:PASTE_YOUR_TELEGRAM_BOT_TOKEN_HERE

# --- Strava (strava.com/settings/api) ---
STRAVA_CLIENT_ID=12345
STRAVA_CLIENT_SECRET=paste_your_strava_client_secret

# Сегмент по умолчанию — из задачи. Можно переопределить.
SEGMENT_ID=769755

# ============================================================
#  ХОСТИНГ НА VERCEL (webhook-режим, бесплатно)
# ============================================================

# Публичный адрес приложения на Vercel. Именно на него Telegram шлёт
# апдейты, и от него же строится Strava redirect_uri.
# Локально можно оставить http://localhost:8000 (polling-режим через bot.main).
OAUTH_PUBLIC_BASE=https://your-app.vercel.app

# Секрет вебхука Telegram: любая случайная строка (буквы/цифры/-/_).
# Тем же значением регистрируется вебхук (scripts/set_webhook.py) и
# проверяется входящий заголовок X-Telegram-Bot-Api-Secret-Token.
TELEGRAM_WEBHOOK_SECRET=change_me_to_a_random_string

# --- Upstash Redis (хранилище токенов + OAuth-state) ---
# Бесплатно создаётся через Vercel Marketplace (Upstash) — переменные
# подставляются в проект автоматически. Локально можно не задавать:
# без них storage падает обратно на файловый bot/data/tokens.json.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Локальный polling-режим (bot.main), для Vercel не нужно ---
OAUTH_HOST=localhost
OAUTH_PORT=8000
