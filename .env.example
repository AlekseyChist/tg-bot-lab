# Скопируй в .env и заполни

# --- Telegram (@BotFather) ---
BOT_TOKEN=123456:PASTE_YOUR_TELEGRAM_BOT_TOKEN_HERE

# --- Strava (strava.com/settings/api) ---
STRAVA_CLIENT_ID=12345
STRAVA_CLIENT_SECRET=paste_your_strava_client_secret

# Сегмент по умолчанию — из задачи. Можно переопределить.
SEGMENT_ID=769755

# OAuth callback. Для локального теста оставь как есть и поставь
# "Authorization Callback Domain = localhost" в настройках Strava-приложения.
# Для реального чата: OAUTH_PUBLIC_BASE=https://твой-домен (туннель/сервер),
# а домен в настройках Strava = твой-домен.
OAUTH_HOST=localhost
OAUTH_PORT=8000
OAUTH_PUBLIC_BASE=http://localhost:8000
